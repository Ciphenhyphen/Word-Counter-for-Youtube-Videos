{
    "manifest_version": 2,
    "name": "yt-chart-ext",
    "version": "1.0",
    "description": "View word occurrence of a video on youtube.",
   
    "icons": {
        "48": "icons.message.svg"
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "yt_chart_ext@example.org"
        }
    },

    "options_ui": {
        "page": "options.html",
        "browser_style": true
    },

    "background": {
        "scripts": [ "background.js" ]
    },
    
    "permissions": ["contextMenus", "nativeMessaging"]

}